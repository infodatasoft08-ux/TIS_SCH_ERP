<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admit Card</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

        :root {
            --primary-color: #203b82;
            --text-main: #1f2937;
            --text-muted: #6b7280;
            --border-color: #e5e7eb;
            --bg-light: #f9fafb;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--text-main);
            line-height: 1.5;
            margin: 0;
            padding: 40px;
            background: white;
            font-size: 13px;
        }

        @page {
            size: A4;
            margin: 0;
        }

        .admit-card-container {
            max-width: 800px;
            margin: auto;
            margin-top: 4px;
            position: relative;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            border-bottom: 2px solid var(--primary-color);
            padding-bottom: 20px;
            margin-bottom: 30px;
        }

        .school-info {
            flex: 2;
        }

        .school-name {
            font-size: 24px;
            font-weight: 700;
            color: var(--primary-color);
            margin: 0;
            text-transform: uppercase;
        }

        .school-tagline {
            font-style: italic;
            color: var(--text-muted);
            font-size: 12px;
            margin-bottom: 8px;
        }

        .school-address {
            font-size: 11px;
            color: var(--text-muted);
            max-width: 400px;
        }

        .logo-container {
            width: 100px;
            height: 100px;
            flex: 1;
            text-align: right;
        }

        .logo {
            max-width: 100%;
            height: auto;
        }

        .title-section {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            border-bottom: 1px dashed var(--border-color);
            padding-bottom: 15px;
        }

        .admit-card-title {
            font-size: 20px;
            font-weight: 700;
            color: var(--primary-color);
            border-left: 4px solid var(--primary-color);
            padding-left: 12px;
            text-transform: uppercase;
        }

        .exam-session {
            text-align: right;
            font-weight: 600;
            color: var(--text-main);
            background: #eef2ff;
            padding: 6px 12px;
            border-radius: 6px;
            font-size: 12px;
        }

        .details-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 40px;
            background: var(--bg-light);
            padding: 20px;
            border-radius: 8px;
            border: 1px solid var(--border-color);
        }

        .section-title {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
            margin: 0 0 12px 0;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 4px;
            font-weight: 700;
        }

        .detail-row {
            display: flex;
            margin-bottom: 8px;
        }

        .detail-label {
            width: 120px;
            font-weight: 600;
            color: var(--text-muted);
        }

        .detail-value {
            flex: 1;
            font-weight: 600;
            color: var(--text-main);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 40px;
        }

        th {
            background: var(--primary-color);
            text-align: left;
            padding: 12px;
            font-weight: 600;
            color: white;
            border-bottom: 1px solid var(--border-color);
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        td {
            padding: 12px;
            border-bottom: 1px solid var(--border-color);
            font-size: 12px;
        }

        .items-table tbody tr:nth-child(even) {
            background: #fafafa;
        }

        .instructions {
            margin-top: 30px;
            padding: 20px;
            background: #fffbeb;
            border: 1px solid #fef3c7;
            border-radius: 8px;
        }

        .instructions h4 {
            margin: 0 0 10px 0;
            color: #b45309;
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
        }

        .instructions ol {
            margin: 0;
            padding-left: 20px;
            color: #78350f;
            font-size: 11px;
        }

        .instructions li {
            margin-bottom: 6px;
        }

        .footer {
            margin-top: 60px;
            padding-top: 20px;
            border-top: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }

        .footer-note {
            font-size: 11px;
            color: var(--text-muted);
        }

        .signature-area {
            text-align: right;
        }

        .signature-line {
            border-top: 1px solid var(--text-main);
            width: 200px;
            margin-top: 40px;
            padding-top: 8px;
            font-weight: 700;
            font-size: 12px;
            text-align: center;
        }

        /* Watermark */
        .watermark {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-30deg);
            opacity: 0.06;
            width: 40%;
            z-index: 0;
            pointer-events: none;
        }
    </style>
</head>

<body>
    <div class="admit-card-container">
        {{#if cmcLogo}}
        <img src="{{cmcLogo}}" class="watermark" alt="Watermark">
        {{/if}}

        <!-- Header -->
        <div class="header">
            <div class="school-info">
                <h1 class="school-name">Times International School</h1>
                <p class="school-tagline">Commited to Excellence</p>
                <p class="school-address">
                    TIMES INTERNATIONAL SCHOOL<br>
                    J57H+PG6, Mohammadpur Rd, Sultanganj,<br>
                    Muhammadpur, Patna, Bihar 800006<br>
                    MOB:- 6200491833. Email :- timesschoolpatna3@gmail.com
                </p>
            </div>
            <div class="logo-container">
                {{#if logoData}}
                <img src="{{logoData}}" alt="School Logo" class="logo">
                {{/if}}
            </div>
        </div>

        <!-- Title Section -->
        <div class="title-section">
            <div class="admit-card-title">EXAMINATION ADMIT CARD</div>
            <div class="exam-session">{{student.academic_year_name}}</div>
        </div>

        <!-- Student Details Grid -->
        <div class="details-grid">
            <div>
                <h3 class="section-title">Student Details</h3>
                <div class="detail-row">
                    <div class="detail-label">Student Name:</div>
                    <div class="detail-value">{{student.name}}</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Father's Name:</div>
                    <div class="detail-value">{{student.fathers_name}}</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Roll Number:</div>
                    <div class="detail-value">{{student.roll_no}}</div>
                </div>
            </div>
            <div>
                <h3 class="section-title">Examination Details</h3>
                <div class="detail-row">
                    <div class="detail-label">Exam Name:</div>
                    <div class="detail-value">{{exam_name}}</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Grade / Class:</div>
                    <div class="detail-value">{{student.grade_name}} / {{student.class_name}}</div>
                </div>
            </div>
        </div>

        <!-- Exam Routine Table -->
        <h3 class="section-title" style="border: none; margin-bottom: 8px;">Examination Schedule</h3>
        <table class="items-table">
            <thead>
                <tr>
                    <th width="10%">S.No</th>
                    <th width="40%">Subject</th>
                    <th width="25%">Date</th>
                    <th width="25%">Time</th>
                </tr>
            </thead>
            <tbody>
                {{#each routine}}
                <tr>
                    <td>{{add @index 1}}</td>
                    <td><strong>{{subject_name}}</strong></td>
                    <td>{{exam_date}}</td>
                    <td>{{time}}</td>
                </tr>
                {{/each}}
            </tbody>
        </table>

        <!-- Instructions -->
        <div class="instructions">
            <h4>Instructions to Candidates</h4>
            <ol>
                <li>Candidates must carry this Admit Card to the examination hall for every session.</li>
                <li>Please report to the examination hall at least 15 minutes before the start time.</li>
                <li>No electronic devices, calculators, or mobile phones are allowed inside the examination hall.</li>
                <li>Candidates found using unfair means will be disqualified immediately.</li>
                <li>Ensure all fee dues are fully cleared; otherwise, entry to the examination may be restricted.</li>
            </ol>
        </div>

        <!-- Footer -->
        <div class="footer">
            <div class="footer-note">
                Generated internally by CMC Management System<br>
                Verification Code: {{admitCardCode}}
            </div>
            <div class="signature-area">
                <div class="signature-line">Controller of Examinations</div>
            </div>
        </div>
    </div>
</body>

</html>