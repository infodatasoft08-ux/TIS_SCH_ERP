<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admission Form - {{student.user_name}}</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');

        :root {
            --primary-blue: #1e40af;
            --text-slate: #1e293b;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--text-slate);
            margin: 0;
            padding: 40px;
            background: white;
            line-height: 1.6;
        }

        .form-container {
            border: 2px solid var(--primary-blue);
            padding: 30px;
            position: relative;
            min-height: 250mm;
        }

        /* Watermark */
        .watermark {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-0deg);
            opacity: 0.08;
            width: 400px;
            z-index: -1;
            pointer-events: none;
        }

        .header {
            display: flex;
            align-items: center;
            border-bottom: 3px double var(--primary-blue);
            padding-bottom: 20px;
            margin-bottom: 30px;
        }

        .logo-box {
            width: 100px;
            height: 100px;
            margin-right: 30px;
        }

        .logo {
            max-width: 100%;
            height: auto;
        }

        .school-info {
            flex: 1;
            text-align: center;
        }

        .school-name {
            font-size: 32px;
            font-weight: 800;
            color: var(--primary-blue);
            margin: 0;
            text-transform: uppercase;
        }

        .tagline {
            font-size: 16px;
            font-style: italic;
            color: var(--primary-blue);
        }

        .address-box {
            font-size: 12px;
            margin-top: 4px;
        }

        .form-title {
            text-align: center;
            font-size: 22px;
            font-weight: 700;
            text-decoration: underline;
            margin: 10px 0;
            color: var(--primary-blue);
        }

        .section-title {
            background: var(--primary-blue);
            color: white;
            padding: 5px 15px;
            font-size: 16px;
            font-weight: 600;
            margin: 10px 0 10px 0;
            border-radius: 4px;
        }

        .data-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px 20px;
        }

        .data-item {
            display: flex;
            border-bottom: 1px dotted #cbd5e1;
            padding-bottom: 5px;
        }

        .label {
            font-weight: 700;
            width: 160px;
            font-size: 13px;
            color: var(--primary-blue);
        }

        .value {
            flex: 1;
            font-size: 13px;
        }

        .photo-box {
            width: 110px;
            height: 110px;
            border: 2px dashed #94a3b8;
            position: absolute;
            top: 174px;
            right: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            color: #64748b;
            text-align: center;
        }

        .declaration {
            margin-top: 30px;
            font-size: 12px;
            border-top: 1px solid #e2e8f0;
            padding-top: 15px;
        }

        .signatures {
            margin-top: 70px;
            display: flex;
            justify-content: space-between;
        }

        .sig-box {
            text-align: center;
            width: 200px;
        }

        .sig-line {
            border-top: 1px solid var(--text-slate);
            margin-bottom: 3px;
        }

        .student-photo {
            width: 110px;
            height: 110px;
            object-fit: cover;
        }
    </style>
</head>

<body>
    <div class="form-container">
        {{#if logoData}}
        <img src="{{logoData}}" class="watermark" alt="Watermark Logo">
        {{/if}}

        <div class="header">
            <div class="logo-box">
                {{#if logoData}}
                <img src="{{logoData}}" alt="Logo" class="logo">
                {{/if}}
            </div>
            <div class="school-info">
                <h1 class="school-name">TIMES INTERNATIONAL SCHOOL</h1>
                <div class="tagline">Commited to Excellence</div>
                <div class="address-box">
                    J57H+PG6, Mohammadpur Rd, Sultanganj, Muhammadpur, Patna, Bihar 800006<br>
                    Mob: 8102657225 | Email: timesschoolpatna3@gmail.com
                </div>
            </div>
        </div>

        <div class="photo-box">
            {{#if student.user_avatar_url}}
            <img src="{{student.user_avatar_url}}" alt="Student Photo" class="student-photo">
            {{else}}
            Affix Student<br>Passport Photo
            {{/if}}
        </div>

        <h2 class="form-title">STUDENT ADMISSION FORM</h2>

        <div class="section-title">Admission Details</div>
        <div class="data-grid">
            <div class="data-item"><span class="label">Admission No:</span><span
                    class="value">{{student.admission_no}}</span></div>
            <div class="data-item"><span class="label">Admission Date:</span><span
                    class="value">{{student.admission_date}}</span></div>
            <div class="data-item"><span class="label">Academic Year:</span><span
                    class="value">{{student.academic_year_name}}</span></div>
            <div class="data-item"><span class="label">Class/Grade:</span><span class="value">{{student.grade_name}} -
                    {{student.class_name}}</span></div>
            <div class="data-item"><span class="label">Roll Number:</span><span class="value">{{student.roll_no}}</span>
            </div>
        </div>

        <div class="section-title">Student Particulars</div>
        <div class="data-grid">
            <div class="data-item" style="grid-column: span 2;"><span class="label">Full Name:</span><span class="value"
                    style="font-weight: 600; font-size: 15px;">{{student.user_name}}</span></div>
            <div class="data-item"><span class="label">Date of Birth:</span><span
                    class="value">{{student.date_of_birth}}</span></div>
            <div class="data-item"><span class="label">Gender:</span><span class="value"
                    style="text-transform: capitalize;">{{student.gender}}</span></div>
            <div class="data-item"><span class="label">Blood Group:</span><span
                    class="value">{{student.blood_group}}</span></div>
            <div class="data-item"><span class="label">Aadhar No:</span><span
                    class="value">{{student.user_adhar_no}}</span></div>
        </div>

        <div class="section-title">Parent/Guardian Information</div>
        <div class="data-grid">
            <div class="data-item"><span class="label">Father's Name:</span><span
                    class="value">{{student.fathers_name}}</span></div>
            <div class="data-item"><span class="label">Mother's Name:</span><span
                    class="value">{{student.mothers_name}}</span></div>
            <div class="data-item"><span class="label">Contact Number:</span><span
                    class="value">{{student.phone}}</span></div>
            <div class="data-item"><span class="label">Mother's Contact:</span><span
                    class="value">{{student.mother_contect}}</span></div>
            <div class="data-item"><span class="label">Email:</span><span class="value">{{student.email}}</span></div>
            <div class="data-item"><span class="label">Occupation:</span><span
                    class="value">{{student.father_occupation}}</span></div>
        </div>

        <div class="section-title">Residential Address</div>
        <div class="data-item" style="border: none;">
            <span class="label">Present Address:</span>
            <span class="value">{{student.user_address}}</span>
        </div>

        <div class="declaration">
            <strong>Declaration:</strong> I hereby declare that the information provided above is true to the best of my
            knowledge. I agree to abide by the rules and regulations of Niyati Public School.
        </div>

        <div class="signatures">
            <div class="sig-box">
                <div class="sig-line"></div>
                <div class="sig-label">Parent's Signature</div>
            </div>
            <div class="sig-box">
                <div class="sig-line"></div>
                <div class="sig-label">Principal's Signature</div>
            </div>
        </div>
    </div>
</body>

</html>