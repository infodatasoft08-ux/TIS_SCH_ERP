<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <title>Teacher Profile - Niyati Public School</title>
    <style>
        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            color: #333;
            margin: 0;
            padding: 40px;
            background-color: #fff;
        }

        .header {
            text-align: center;
            border-bottom: 2px solid #1e3a8a;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }

        .school-name {
            color: #1e3a8a;
            font-size: 28px;
            font-weight: bold;
            margin: 0;
            text-transform: uppercase;
        }

        .school-tagline {
            color: #64748b;
            font-size: 14px;
            margin-top: 5px;
            font-style: italic;
            padding-left: 192px;
        }

        .profile-container {
            display: flex;
            align-items: flex-start;
            margin-bottom: 40px;
        }

        .profile-image-container {
            width: 150px;
            height: 150px;
            border-radius: 8px;
            overflow: hidden;
            border: 3px solid #e2e8f0;
            margin-right: 30px;
            float: left;
        }

        .profile-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .profile-details {
            flex: 1;
            padding-top: 10px;
        }

        .teacher-name {
            font-size: 24px;
            font-weight: bold;
            color: #0f172a;
            margin: 0 0 10px 0;
        }

        .info-row {
            margin-bottom: 8px;
            font-size: 14px;
        }

        .info-label {
            font-weight: bold;
            color: #475569;
            width: 120px;
            display: inline-block;
        }

        .section-title {
            font-size: 18px;
            font-weight: bold;
            color: #1e3a8a;
            border-bottom: 1px solid #cbd5e1;
            padding-bottom: 8px;
            margin-top: 30px;
            margin-bottom: 15px;
            clear: both;
        }

        .bio-text {
            font-size: 14px;
            line-height: 1.6;
            color: #334155;
            text-align: justify;
        }

        .footer {
            margin-top: 50px;
            text-align: center;
            font-size: 12px;
            color: #94a3b8;
            border-top: 1px solid #e2e8f0;
            padding-top: 20px;
        }

        /* Watermark */
        .watermark {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-0deg);
            opacity: 0.08;
            width: 400px;
            z-index: -1;
            pointer-events: none;
        }

        .header-logo {
            position: absolute;
            left: 20px;
            width: 100px;
            top: 0;
        }
    </style>
</head>

<body>
    {{#if logoData}}
    <img src="{{logoData}}" class="watermark" alt="Watermark">
    {{/if}}

    <div class="header">
        <img src="{{logoData}}" class="header-logo" alt="Header Logo">
        <div style="width: 100%;">
            <h1 class="school-name">Niyati Public School</h1>
            <p class="school-tagline">Destiny for Excellence</p>
        </div>
    </div>

    <div class="profile-container">
        <div class="profile-image-container">
            {{#if teacher.avatar_url}}
            <img src="{{teacher.avatar_url}}" class="profile-image" alt="Teacher Photo">
            {{else}}
            <div
                style="width: 100%; height: 100%; background-color: #f1f5f9; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 48px; text-align: center; line-height: 150px;">
                👤
            </div>
            {{/if}}
        </div>
        <div class="profile-details">
            <h2 class="teacher-name">{{teacher.name}}</h2>

            <div class="info-row">
                <span class="info-label">Qualification:</span>
                <span>{{teacher.qualification}}</span>
            </div>

            <div class="info-row">
                <span class="info-label">Employee Code:</span>
                <span>{{teacher.employee_code}}</span>
            </div>

            <div class="info-row">
                <span class="info-label">Joining Date:</span>
                <span>{{teacher.hire_date}}</span>
            </div>
        </div>
    </div>

    <div class="section-title">About</div>
    <div class="bio-text">
        {{#if teacher.bio}}
        {{teacher.bio}}
        {{else}}
        A dedicated and passionate educator committed to fostering a positive learning environment and helping students
        achieve their full potential at Niyati Public School.
        {{/if}}
    </div>

    {{#if subjects.length}}
    <div class="section-title">Subjects Taught</div>
    <ul class="bio-text">
        {{#each subjects}}
        <li>{{this.name}}</li>
        {{/each}}
    </ul>
    {{/if}}

    <div class="footer">
        <p>This is a computer-generated document from Niyati Public School.</p>
        <p>Generated on: {{generation_date}}</p>
    </div>
</body>

</html>