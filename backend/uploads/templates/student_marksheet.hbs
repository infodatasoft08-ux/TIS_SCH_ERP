<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Student Marksheet</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Cinzel:wght@600;700&display=swap');

        body {
            font-family: 'Montserrat', sans-serif;
            margin: 0;
            padding: 0;
            width: 794px;
            /* A4 width */
            height: 1123px;
            /* A4 height */
            background-color: #fff;
            color: #333;
            box-sizing: border-box;
        }

        .container {
            width: 100%;
            height: 100%;
            padding: 40px;
            box-sizing: border-box;
            position: relative;
        }

        /* Decorative Borders */
        .border-outer {
            position: absolute;
            top: 20px;
            left: 20px;
            right: 20px;
            bottom: 20px;
            border: 2px solid #2c3e50;
            pointer-events: none;
        }

        .border-inner {
            position: absolute;
            top: 26px;
            left: 26px;
            right: 26px;
            bottom: 26px;
            border: 1px solid #34495e;
            pointer-events: none;
        }

        /* Header Section */
        .header {
            text-align: center;
            margin-bottom: 30px;
            margin-top: 20px;
            position: relative;
        }

        .school-name {
            font-family: 'Cinzel', serif;
            font-size: 28px;
            font-weight: 700;
            color: #1a252f;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin: 0 0 10px 0;
        }

        .marksheet-title {
            font-size: 18px;
            font-weight: 600;
            color: #2c3e50;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin: 0;
            padding-bottom: 15px;
            border-bottom: 2px solid #e2e8f0;
            display: inline-block;
            width: 60%;
        }

        /* Student & Exam Details Section */
        .details-section {
            display: flex;
            justify-content: space-between;
            margin-bottom: 30px;
            padding: 0 20px;
        }

        .details-col {
            width: 48%;
        }

        .detail-row {
            display: flex;
            margin-bottom: 8px;
            font-size: 12px;
        }

        .detail-label {
            font-weight: 600;
            width: 120px;
            color: #475569;
        }

        .detail-value {
            font-weight: 500;
            color: #1e293b;
        }

        /* Table Section */
        .table-container {
            margin-bottom: 30px;
            padding: 0 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
        }

        th,
        td {
            border: 1px solid #cbd5e1;
            padding: 10px;
            text-align: center;
        }

        th {
            background-color: #f1f5f9;
            color: #334155;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 11px;
        }

        th:first-child,
        td:first-child {
            text-align: left;
        }

        /* Alternate row color */
        tbody tr:nth-child(even) {
            background-color: #f8fafc;
        }

        /* Summary Section */
        .summary-section {
            padding: 0 20px;
            display: flex;
            justify-content: flex-end;
        }

        .summary-box {
            border: 1px solid #cbd5e1;
            padding: 15px 20px;
            background-color: #f8fafc;
            width: 300px;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
            font-size: 13px;
        }

        .summary-row:last-child {
            margin-bottom: 0;
            padding-top: 8px;
            border-top: 1px solid #cbd5e1;
            font-weight: 700;
            font-size: 14px;
        }

        .summary-label {
            font-weight: 600;
            color: #475569;
        }

        .summary-value {
            font-weight: 600;
            color: #1e293b;
        }

        /* Footer */
        .footer {
            position: absolute;
            bottom: 60px;
            left: 60px;
            right: 60px;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }

        .signature-box {
            text-align: center;
            width: 150px;
        }

        .signature-line {
            border-top: 1px solid #333;
            margin-bottom: 5px;
        }

        .signature-title {
            font-size: 11px;
            font-weight: 500;
            color: #475569;
        }

        .print-date {
            font-size: 10px;
            color: #94a3b8;
            position: absolute;
            bottom: 20px;
            right: 40px;
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="border-outer"></div>
        <div class="border-inner"></div>

        <div class="header">
            <h1 class="school-name">Times International School</h1>
            <h2 class="marksheet-title">Statement of Marks</h2>
        </div>

        <div class="details-section">
            <div class="details-col">
                <div class="detail-row">
                    <span class="detail-label">Student Name:</span>
                    <span class="detail-value">{{student.name}}</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Roll Number:</span>
                    <span class="detail-value">{{student.roll_no}}</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Class/Grade:</span>
                    <span class="detail-value">{{student.grade_name}}</span>
                </div>
            </div>
            <div class="details-col">
                <div class="detail-row">
                    <span class="detail-label">Examination:</span>
                    <span class="detail-value">{{exam.name}}</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Exam Date:</span>
                    <span class="detail-value">{{exam.formattedDate}}</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Academic Year:</span>
                    <span class="detail-value">{{student.academic_year_name}}</span>
                </div>
            </div>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Subject</th>
                        <th>Max Marks</th>
                        <th>Marks Obtained</th>
                        <th>Grade</th>
                        <th>Remarks</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each exam.subjects}}
                    <tr>
                        <td>{{this.subject_name}}</td>
                        <td>{{this.max_marks}}</td>
                        <td>{{#if (eq this.attendance_status "Absent")}}AB{{else}}{{this.marks_obtained}}{{/if}}</td>
                        <td>{{this.grade}}</td>
                        <td>{{#if (eq this.attendance_status "Absent")}}Absent{{else}}{{this.attendance_status}}{{/if}}
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>

        <div class="summary-section">
            <div class="summary-box">
                <div class="summary-row">
                    <span class="summary-label">Total Maximum Marks:</span>
                    <span class="summary-value">{{totalMax}}</span>
                </div>
                <div class="summary-row">
                    <span class="summary-label">Total Marks Obtained:</span>
                    <span class="summary-value">{{totalObtained}}</span>
                </div>
                <div class="summary-row">
                    <span class="summary-label">Percentage:</span>
                    <span class="summary-value">{{percentage}}%</span>
                </div>
            </div>
        </div>

        <div class="footer">
            <div class="signature-box">
                <div class="signature-line"></div>
                <div class="signature-title">Class Teacher</div>
            </div>
            <div class="signature-box">
                <div class="signature-line"></div>
                <div class="signature-title">Principal</div>
            </div>
        </div>

        <div class="print-date">Generated on: {{currentDate}}</div>
    </div>
</body>

</html>